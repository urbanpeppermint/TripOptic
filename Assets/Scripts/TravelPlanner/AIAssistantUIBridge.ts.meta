  InputLines:
    - '// @input AssignableType geminiAssistant {"hint":"Primary trip assistant."}'
    - '// @input AssignableType_1 asrQueryController {"hint":"Optional ASR controller that emits user speech transcripts."}'
    - '// @input AssignableType_2 startAssistantButton {"hint":"Voice capture: assign PinchButton under Btn_VoiceMode_Placeholder. Pinch = welcome (once) + start/stop speech-to-text."}'
    - '// @input AssignableType_3 micMuteToggle {"hint":"SIK Toggle on Btn_Mic: ON = muted (blocks capture), OFF = unmuted. Does not start STT."}'
    - '// @input AssignableType_4 planTripButton {"hint":"Button to submit current captured trip draft to Gemini."}'
    - '// @input Component.Text hintText {"hint":"Optional hint line for setup/debug status."}'
    - '// @input AssignableType_5 travelPlannerController {"hint":"Mirrors Gemini trip draft into the center itinerary panel (TripState)."}'
    - '// @input AssignableType_6 keyboardToggleButton {"hint":"Keyboard intake: assign PinchButton under Btn_Keyboard_Placeholder. Does not start the mic."}'
    - '// @input AssignableType_7 keyboardConfirmButton {"hint":"Pinch to confirm current keyboard text entry for active step. Shown only while keyboard mode is on (hidden during voice-only)."}'
    - '// @input Component.Text keyboardEntryText {"hint":"Dedicated line for typed trip fields — assign VoiceListening_Status_Text (not PromptTitle, not VoiceHint)."}'
    - '// @input Component.Text keyboardPromptText {"hint":"Prompt/status line for keyboard step flow (use PromptSubtitle, not VoiceHint)."}'
    - '// @input SceneObject keyboardModeRoot {"hint":"Optional panel root enabled only in keyboard mode."}'
    - '// @input bool swapVoiceAndKeyboardPinchButtons {"hint":"Enable if the KEYBOARD row runs voice and Voice row opens keyboard (overlapping prefabs / wrong drag-drop)."}'
    - '// @input AssignableType_8 clearInputsButton {"hint":"Pinch to clear trip draft, voice prefs, and plan widgets (fixes bad parses). Assign PinchButton on Btn_ClearInputs."}'
